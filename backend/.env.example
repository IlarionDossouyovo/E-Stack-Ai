# Server
PORT=4000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=estack_ai
DB_USER=postgres
DB_PASSWORD=postgres
DB_SYNCHRONIZE=true

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# IA - Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2:latest
OLLAMA_MODELS=llama3.2:latest,llama3.1:8b,qwen2.5-coder:7b,phi3:mini

# Frontend
FRONTEND_URL=http://localhost:3000

# Optional - OpenAI (if using)
# OPENAI_API_KEY=sk-...
